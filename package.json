{
  "name": "tan-st",
  "version": "1.0.0",
  "private": true,
  "description": "tan.st Cloudflare Worker shortener",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "cf-typegen": "wrangler types",
    "cf-typecheck": "wrangler types --check",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "check": "pnpm run cf-typecheck && pnpm exec tsc --noEmit && pnpm exec tsc --noEmit -p test/tsconfig.json && pnpm test && pnpm run format:check && pnpm run lint",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.27.0"
}
